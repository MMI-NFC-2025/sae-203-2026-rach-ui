---
/**
 * src/pages/contact.astro
 * Page Contact du festival Lumimix
 */

import Layout from "../layouts/Layout.astro";
import Footer from "../components/Footer.astro";
---

<Layout>
    <!-- -- En-tęte décoratif -- -->
    <div
        class="relative overflow-hidden bg-linear-to-b from-[#e8705a] via-[#c0407e] to-[#ede8d5] h-32"
    >
        <img
            src="/cloud.svg"
            alt=""
            aria-hidden="true"
            class="absolute top-0 left-0 w-full h-auto pointer-events-none opacity-70"
        />
        <img
            src="/drone.svg"
            alt=""
            aria-hidden="true"
            class="absolute top-0 left-0 w-full h-auto pointer-events-none opacity-50"
        />
    </div>

    <div class="bg-[#ede8d5] px-6 py-10 max-w-2xl mx-auto space-y-14">
        <!-- -- TITRE -- -->
        <div>
            <h1
                class="text-3xl font-black uppercase tracking-tight text-[#e8705a] mb-2"
            >
                Contactez-nous
            </h1>
            <div class="w-16 h-1 bg-[#c0407e] rounded-full"></div>
        </div>

        <!-- -- COORDONNÉES -- -->
        <section>
            <h2
                class="text-sm font-black uppercase tracking-widest text-[#1a1a2e] mb-5"
            >
                Coordonnées
            </h2>
            <dl class="space-y-3 text-sm">
                {
                    [
                        {
                            label: "Email général",
                            val: "contact@lumimix-festival.fr",
                        },
                        { label: "Presse", val: "presse@lumimix-festival.fr" },
                        {
                            label: "Partenariats",
                            val: "partenariats@lumimix-festival.fr",
                        },
                        {
                            label: "Accessibilité",
                            val: "accessibilite@lumimix-festival.fr",
                        },
                    ].map(({ label, val }) => (
                        <div class="flex flex-wrap gap-1">
                            <dt class="font-black text-[#1a1a2e]">{label} :</dt>
                            <dd>
                                <a
                                    href={`mailto:${val}`}
                                    class="text-[#3d1080] underline underline-offset-2 break-all
                                      hover:text-[#c0407e] transition-colors"
                                >
                                    {val}
                                </a>
                            </dd>
                        </div>
                    ))
                }
                <div class="flex flex-wrap gap-1">
                    <dt class="font-black text-[#1a1a2e]">Téléphone :</dt>
                    <dd class="text-[#333]">+33 (0)3 84 XX XX XX</dd>
                </div>
                <div>
                    <p class="text-[#555]">Du lundi au vendredi, 9h – 18h</p>
                </div>
                <div>
                    <dt class="font-black text-[#1a1a2e]">Adresse postale</dt>
                </div>
            </dl>
        </section>

        <!-- -- FORMULAIRE -- -->
        <section>
            <h2
                class="text-sm font-black uppercase tracking-widest text-[#1a1a2e] mb-5"
            >
                Formulaire de contact
            </h2>

            <form
                id="contact-form"
                class="bg-[#f5efe0] border border-[#e0d5be] rounded-2xl p-6 space-y-4"
            >
                <!-- Nom + Prénom -->
                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label
                            for="nom"
                            class="block text-xs font-black uppercase tracking-widest text-[#1a1a2e] mb-1"
                        >
                            Nom
                        </label>
                        <input
                            id="nom"
                            name="nom"
                            type="text"
                            required
                            autocomplete="family-name"
                            class="w-full bg-[#ede8d5] border border-[#d0c8b0] rounded-lg px-3 py-2
                                      text-sm text-[#1a1a2e] placeholder-[#aaa]
                                      focus:outline-none focus:ring-2 focus:ring-[#c0407e]/50"
                        />
                    </div>
                    <div>
                        <label
                            for="prenom"
                            class="block text-xs font-black uppercase tracking-widest text-[#1a1a2e] mb-1"
                        >
                            Prénom
                        </label>
                        <input
                            id="prenom"
                            name="prenom"
                            type="text"
                            required
                            autocomplete="given-name"
                            class="w-full bg-[#ede8d5] border border-[#d0c8b0] rounded-lg px-3 py-2
                                      text-sm text-[#1a1a2e] placeholder-[#aaa]
                                      focus:outline-none focus:ring-2 focus:ring-[#c0407e]/50"
                        />
                    </div>
                </div>

                <!-- Email -->
                <div>
                    <label
                        for="email"
                        class="block text-xs font-black uppercase tracking-widest text-[#1a1a2e] mb-1"
                    >
                        Email
                    </label>
                    <input
                        id="email"
                        name="email"
                        type="email"
                        required
                        autocomplete="email"
                        class="w-full bg-[#ede8d5] border border-[#d0c8b0] rounded-lg px-3 py-2
                                  text-sm text-[#1a1a2e] placeholder-[#aaa]
                                  focus:outline-none focus:ring-2 focus:ring-[#c0407e]/50"
                    />
                </div>

                <!-- Sujet -->
                <div>
                    <label
                        for="sujet"
                        class="block text-xs font-black uppercase tracking-widest text-[#1a1a2e] mb-1"
                    >
                        Sujet
                    </label>
                    <input
                        id="sujet"
                        name="sujet"
                        type="text"
                        required
                        class="w-full bg-[#ede8d5] border border-[#d0c8b0] rounded-lg px-3 py-2
                                  text-sm text-[#1a1a2e] placeholder-[#aaa]
                                  focus:outline-none focus:ring-2 focus:ring-[#c0407e]/50"
                    />
                </div>

                <!-- Message -->
                <div>
                    <label
                        for="message"
                        class="block text-xs font-black uppercase tracking-widest text-[#1a1a2e] mb-1"
                    >
                        Message
                    </label>
                    <textarea
                        id="message"
                        name="message"
                        rows="5"
                        required
                        class="w-full bg-[#ede8d5] border border-[#d0c8b0] rounded-lg px-3 py-2
                                     text-sm text-[#1a1a2e] placeholder-[#aaa] resize-none
                                     focus:outline-none focus:ring-2 focus:ring-[#c0407e]/50"
                    ></textarea>
                </div>

                <!-- Bouton + feedback -->
                <div class="flex justify-end items-center gap-4">
                    <p
                        id="form-status"
                        class="text-xs text-[#3d1080] font-semibold hidden"
                    >
                    </p>
                    <button
                        type="submit"
                        class="px-8 py-3 rounded-full text-white font-black uppercase
                                   tracking-widest text-xs shadow active:scale-95 transition-transform"
                        style="background:linear-gradient(135deg,#e8705a,#c0407e)"
                    >
                        Envoyer
                    </button>
                </div>
            </form>
        </section>

        <!-- -- RÉSEAUX SOCIAUX -- -->
        <section>
            <h2
                class="text-sm font-black uppercase tracking-widest text-[#1a1a2e] mb-4"
            >
                Réseaux sociaux
            </h2>
            <p class="text-sm text-[#444] leading-relaxed mb-4">
                Suivez-nous pour toute l'actualité du festival, les annonces
                d'artistes et les coulisses de Lumimix.
            </p>
            <ul class="space-y-2 text-sm mb-4">
                <li>
                    <a
                        href="https://instagram.com/lumimix_festival"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="font-black text-[#1a1a2e] hover:text-[#c0407e] transition-colors"
                    >
                        Instagram :
                    </a>
                    <span class="text-[#555]"> @lumimix_festival</span>
                </li>
                <li>
                    <a
                        href="https://facebook.com/lumimix"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="font-black text-[#1a1a2e] hover:text-[#c0407e] transition-colors"
                    >
                        Facebook :
                    </a>
                    <span class="text-[#555]"> Lumimix</span>
                </li>
                <li>
                    <a
                        href="https://youtube.com/@lumimixfestival"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="font-black text-[#1a1a2e] hover:text-[#c0407e] transition-colors"
                    >
                        YouTube :
                    </a>
                    <span class="text-[#555]"> Lumimix Festival</span>
                </li>
            </ul>
            <p class="font-black text-[#3d1080] text-sm">#Lumimix2026</p>
        </section>

        <!-- -- BESOIN D'AIDE -- -->
        <section>
            <h2
                class="text-sm font-black uppercase tracking-widest text-[#1a1a2e] mb-3"
            >
                Besoin d'aide ?
            </h2>
            <p class="text-sm text-[#444] leading-relaxed mb-5">
                Consultez notre FAQ dans la section Infos Pratiques pour trouver
                rapidement des réponses aux questions les plus fréquentes.
            </p>
            <a
                href="/infos-pratiques#faq"
                class="inline-block px-6 py-3 rounded-full text-white font-black uppercase
                      tracking-widest text-xs shadow active:scale-95 transition-transform"
                style="background:linear-gradient(135deg,#e8705a,#c0407e)"
            >
                Voir la FAQ
            </a>
        </section>
    </div>

    <Footer />
</Layout>

<script>
    /* Envoi du formulaire vers PocketBase collection "messages_contact" */
    const form = document.getElementById(
        "contact-form",
    ) as HTMLFormElement | null;
    const status = document.getElementById("form-status") as HTMLElement | null;

    form?.addEventListener("submit", async (e) => {
        e.preventDefault();
        const btn = form.querySelector<HTMLButtonElement>(
            "button[type=submit]",
        );
        if (btn) btn.disabled = true;

        const data = Object.fromEntries(new FormData(form));

        try {
            const res = await fetch(
                "http://127.0.0.1:8090/api/collections/messages_contact/records",
                {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify(data),
                },
            );
            if (res.ok) {
                if (status) {
                    status.textContent = "Message envoyé !";
                    status.classList.remove("hidden", "text-red-600");
                    status.classList.add("text-[#3d1080]");
                }
                form.reset();
            } else {
                throw new Error("server");
            }
        } catch {
            if (status) {
                status.textContent = "Erreur, réessayez.";
                status.classList.remove("hidden", "text-[#3d1080]");
                status.classList.add("text-red-600");
            }
        } finally {
            if (btn) btn.disabled = false;
            if (status) status.classList.remove("hidden");
        }
    });
</script>
