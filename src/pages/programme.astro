---
/**
 * src/pages/programme.astro
 * Page Programme complet du festival Lumimix
 *
 * PocketBase collection "programme" :
 *   ordre (number), jour (string), soustitre (string), artistes (json array)
 */

import Layout from "../layouts/Layout.astro";
import Footer from "../components/Footer.astro";

interface JourProg {
    ordre: number;
    jour: string;
    soustitre: string;
    artistes: string[];
}

let jours: JourProg[] = [];

try {
    const res = await fetch(
        "http://127.0.0.1:8090/api/collections/programme/records?sort=ordre&perPage=10",
        { signal: AbortSignal.timeout(3000) }
    );
    if (res.ok) {
        const data = await res.json();
        const items = data.items ?? [];
        jours = items.map((it: any) => ({
            ordre: it.ordre ?? 0,
            jour: it.jour ?? "",
            soustitre: it.soustitre ?? "",
            artistes: Array.isArray(it.artistes) ? it.artistes : [],
        }));
    }
} catch { /* fallback */ }

if (jours.length === 0) {
    jours = [
        {
            ordre: 1, jour: "Vendredi 7 Aoűt", soustitre: "L'Éveil",
            artistes: ["Klara Nova", "Setareh Ebrahimi", "Milo Tanaka", "Jade Ferreira", "Samuel Okonkwo"],
        },
        {
            ordre: 2, jour: "Samedi 8 Aoűt", soustitre: "La Fusion",
            artistes: ["Léa Moreau", "Soren Brix", "Naomi Okafor", "DJ Pulse", "Valentina Cruz", "Elias Berg"],
        },
        {
            ordre: 3, jour: "Dimanche 9 Aoűt", soustitre: "L'Apogée",
            artistes: ["Marco Vidal", "Ananya Singh", "Mia Johansson", "Théo Lambert", "Rosa Delgado"],
        },
    ];
}
---

<Layout>
    <!-- -- En-tęte décoratif -- -->
    <div class="relative overflow-hidden bg-linear-to-b from-[#e8705a] via-[#c0407e] to-[#ede8d5] h-32">
        <img src="/cloud.svg" alt="" aria-hidden="true"
             class="absolute top-0 left-0 w-full h-auto pointer-events-none opacity-70"/>
    </div>

    <div class="bg-[#ede8d5] px-6 py-10 max-w-2xl mx-auto">

        <!-- -- TITRE -- -->
        <h1 class="text-3xl font-black uppercase tracking-tight mb-2">
            <span class="text-[#3d1080]">Programme </span>
            <span class="text-[#e8705a]">complet</span>
        </h1>
        <div class="w-16 h-1 bg-[#c0407e] rounded-full mb-10"></div>

        <!-- -- ACCORDION -- -->
        <div class="space-y-3" id="accordion">
            {jours.map((j, i) => (
                <div class="accordion-item rounded-2xl overflow-hidden border border-white/60"
                     data-index={i}>
                    <!-- Bouton titre -->
                    <button
                        class="accordion-btn w-full flex items-center justify-between px-5 py-4
                               bg-white/70 hover:bg-white/90 transition-colors duration-200"
                        aria-expanded="false"
                        aria-controls={`panel-${i}`}>
                        <span class="flex items-center gap-3">
                            <span class="flex items-center justify-center w-7 h-7 rounded-full text-white text-xs font-black shrink-0"
                                  style={
                                      i === 0 ? "background:#e8705a" :
                                      i === 1 ? "background:#c0407e" :
                                               "background:#3d1080"
                                  }>
                                {i + 1}
                            </span>
                            <span class="text-left">
                                <span class="block text-sm font-black uppercase tracking-wide text-[#1a1a2e]">
                                    {j.jour}
                                </span>
                                <span class="block text-xs uppercase tracking-widest"
                                      style={
                                          i === 0 ? "color:#e8705a" :
                                          i === 1 ? "color:#c0407e" :
                                                   "color:#3d1080"
                                      }>
                                    {j.soustitre}
                                </span>
                            </span>
                        </span>
                        <!-- icône + / - -->
                        <span class="accordion-icon text-2xl font-thin leading-none select-none"
                              style={
                                  i === 0 ? "color:#e8705a" :
                                  i === 1 ? "color:#c0407e" :
                                           "color:#3d1080"
                              }
                              aria-hidden="true">+</span>
                    </button>

                    <!-- Panneau dépliable -->
                    <div id={`panel-${i}`}
                         class="accordion-panel max-h-0 overflow-hidden transition-[max-height] duration-400 ease-in-out"
                         role="region">
                        <div class="bg-white/50 px-5 py-4 space-y-2">
                            {j.artistes.length > 0 ? (
                                <ul class="space-y-2">
                                    {j.artistes.map((nom: string) => (
                                        <li class="flex items-center gap-3">
                                            <span class="w-1.5 h-1.5 rounded-full shrink-0"
                                                  style={
                                                      i === 0 ? "background:#e8705a" :
                                                      i === 1 ? "background:#c0407e" :
                                                               "background:#3d1080"
                                                  }
                                                  aria-hidden="true"></span>
                                            <span class="text-sm text-[#1a1a2e] font-medium">{nom}</span>
                                        </li>
                                    ))}
                                </ul>
                            ) : (
                                <p class="text-sm text-[#888] italic">
                                    Programme en cours de finalisation.
                                </p>
                            )}
                        </div>
                    </div>
                </div>
            ))}
        </div>

        <!-- -- TÉLÉCHARGEMENT PDF -- -->
        <div class="mt-16 mb-4 flex flex-col items-center gap-6">
            <!-- drone SVG décoratif -->
            <div class="w-40 opacity-80" aria-hidden="true">
                <img src="/drone.svg" alt="" class="w-full h-auto"/>
            </div>
            <a href="/programme.pdf" download
               class="inline-flex items-center gap-3 px-8 py-3 rounded-full text-white font-black
                      uppercase tracking-widest text-sm shadow-lg active:scale-95 transition-transform"
               style="background:linear-gradient(135deg,#e8705a,#c0407e)">
                <!-- icône download -->
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"
                     class="w-5 h-5" aria-hidden="true">
                    <path fill-rule="evenodd"
                          d="M12 2.25a.75.75 0 0 1 .75.75v11.69l3.22-3.22a.75.75 0 1 1 1.06 1.06l-4.5 4.5a.75.75 0 0 1-1.06 0l-4.5-4.5a.75.75 0 1 1 1.06-1.06l3.22 3.22V3a.75.75 0 0 1 .75-.75Zm-9 13.5a.75.75 0 0 1 .75.75v2.25a1.5 1.5 0 0 0 1.5 1.5h13.5a1.5 1.5 0 0 0 1.5-1.5V16.5a.75.75 0 0 1 1.5 0v2.25a3 3 0 0 1-3 3H5.25a3 3 0 0 1-3-3V16.5a.75.75 0 0 1 .75-.75Z"
                          clip-rule="evenodd"/>
                </svg>
                PDF du programme
            </a>
        </div>
    </div>

    <!-- -- BANDE DÉCORATIVE avant footer -- -->
    <div class="relative h-40 overflow-hidden"
         style="background:linear-gradient(to bottom,#ede8d5,#3d1080)">
        <img src="/cloud.svg" alt="" aria-hidden="true"
             class="absolute bottom-0 left-0 w-full h-auto pointer-events-none opacity-50"/>
        <img src="/drone.svg" alt="" aria-hidden="true"
             class="absolute bottom-0 left-0 w-full h-auto pointer-events-none opacity-60"/>
    </div>

    <Footer />
</Layout>

<script>
/* Accordion JS */
document.querySelectorAll<HTMLButtonElement>(".accordion-btn").forEach((btn) => {
    btn.addEventListener("click", () => {
        const panel = btn.nextElementSibling as HTMLElement | null;
        const icon  = btn.querySelector<HTMLElement>(".accordion-icon");
        if (!panel || !icon) return;

        const isOpen = btn.getAttribute("aria-expanded") === "true";

        // Fermer tous les autres
        document.querySelectorAll<HTMLButtonElement>(".accordion-btn").forEach((b) => {
            const p = b.nextElementSibling as HTMLElement | null;
            const ic = b.querySelector<HTMLElement>(".accordion-icon");
            if (b !== btn) {
                b.setAttribute("aria-expanded", "false");
                if (p) p.style.maxHeight = "0";
                if (ic) ic.textContent = "+";
            }
        });

        // Basculer celui-ci
        btn.setAttribute("aria-expanded", isOpen ? "false" : "true");
        icon.textContent = isOpen ? "+" : "-";
        panel.style.maxHeight = isOpen ? "0" : `${panel.scrollHeight}px`;
    });
});
</script>
