---
/**
 * src/pages/infos-pratiques.astro
 * Page Infos Pratiques du festival Lumimix
 *
 * PocketBase collections utilisées :
 *   - "tarifs"   : type (string), prix (string), description (string)
 *   - "faq"      : question (string), reponse (string), ordre (number)
 */

import Layout from "../layouts/Layout.astro";
import Footer from "../components/Footer.astro";

interface Tarif {
    type: string;
    prix: string;
    description: string;
}
interface FaqItem {
    question: string;
    reponse: string;
    ordre: number;
}

let tarifs: Tarif[] = [];
let faqItems: FaqItem[] = [];

try {
    const [rTarifs, rFaq] = await Promise.all([
        fetch(
            "http://127.0.0.1:8090/api/collections/tarifs/records?sort=ordre",
            { signal: AbortSignal.timeout(3000) },
        ),
        fetch("http://127.0.0.1:8090/api/collections/faq/records?sort=ordre", {
            signal: AbortSignal.timeout(3000),
        }),
    ]);
    if (rTarifs.ok) {
        const d = await rTarifs.json();
        tarifs = d.items ?? [];
    }
    if (rFaq.ok) {
        const d = await rFaq.json();
        faqItems = d.items ?? [];
    }
} catch {
    /* fallback */
}

if (tarifs.length === 0) {
    tarifs = [
        { type: "Pass 1 jour", prix: "À partir de XX€", description: "" },
        { type: "Pass 3 jours", prix: "À partir de XX€", description: "" },
    ];
}

if (faqItems.length === 0) {
    faqItems = [
        {
            ordre: 1,
            question: "Quel âge faut-il avoir pour venir ?",
            reponse:
                "Le festival est ouvert aux personnes de 18 ans et plus. Une pièce d'identité sera demandée à l'entrée.",
        },
        {
            ordre: 2,
            question: "Entrer et sortir du festival librement ?",
            reponse:
                "Oui, avec votre bracelet festival, vous pouvez entrer et sortir à votre guise pendant les horaires d'ouverture.",
        },
        {
            ordre: 3,
            question: "Y a-t-il des points de restauration ?",
            reponse:
                "Il y a une dizaine de food trucks et plusieurs bars seront présents sur le site proposant une offre variée (végétarienne, vegan, sans gluten, halal).",
        },
        {
            ordre: 4,
            question: "Le festival est-il accessible ?",
            reponse:
                "Oui, des aménagements spécifiques sont prévus sur toutes les scènes. Contactez-nous à accessibilite@lumimix-festival.fr pour plus d'informations.",
        },
        {
            ordre: 5,
            question: "Que se passe-t-il en cas de mauvais temps ?",
            reponse:
                "Le festival a lieu quelles que soient les conditions météorologiques. Des zones couvertes sont prévues sur le site.",
        },
        {
            ordre: 6,
            question: "Puis-je apporter ma propre nourriture ?",
            reponse:
                "La nourriture est autorisée. Les boissons alcoolisées et les contenants en verre sont strictement interdits.",
        },
        {
            ordre: 7,
            question: "Comment obtenir mon bracelet festival ?",
            reponse:
                "Les bracelets sont distribués à l'entrée du festival sur présentation de votre billet (format papier ou numérique) et d'une pièce d'identité.",
        },
    ];
}
---

<Layout>
    <!-- -- En-tête décoratif -- -->
    <div
        class="relative overflow-hidden bg-linear-to-b from-[#e8705a] via-[#c0407e] to-[#ede8d5] h-32"
    >
        <img
            src="/cloud.svg"
            alt=""
            aria-hidden="true"
            class="absolute top-0 left-0 w-full h-auto pointer-events-none opacity-70"
        />
    </div>

    <div class="bg-[#ede8d5] px-6 py-10 max-w-2xl mx-auto space-y-14">
        <!-- -- TITRE -- -->
        <div>
            <h1
                class="text-3xl font-black uppercase tracking-tight text-[#e8705a] mb-2"
            >
                Infos pratiques
            </h1>
            <div class="w-16 h-1 bg-[#c0407e] rounded-full"></div>
        </div>

        <!-- -- TARIFS -- -->
        <section>
            <h2
                class="text-sm font-black uppercase tracking-widest text-[#1a1a2e] mb-5"
            >
                Tarifs
            </h2>

            <div class="bg-white/60 rounded-2xl p-5 space-y-3 mb-5">
                <p
                    class="text-xs font-black uppercase tracking-widest text-[#3d1080] mb-2"
                >
                    Billetterie
                </p>
                {
                    tarifs.map((t) => (
                        <p class="text-sm text-[#1a1a2e]">
                            <span class="font-black">{t.type} :</span> {t.prix}
                            {t.description ? (
                                <span class="text-[#666]">
                                    {" "}
                                    – {t.description}
                                </span>
                            ) : null}
                        </p>
                    ))
                }
            </div>

            <a
                href="https://billetterie.lumimix-festival.fr"
                target="_blank"
                rel="noopener noreferrer"
                class="inline-block px-6 py-3 rounded-full text-white font-black uppercase
                      tracking-widest text-xs shadow active:scale-95 transition-transform"
                style="background:linear-gradient(135deg,#e8705a,#c0407e)"
            >
                Réserve ta place
            </a>
        </section>

        <!-- -- HÉBERGEMENT -- -->
        <section>
            <h2
                class="text-sm font-black uppercase tracking-widest text-[#1a1a2e] mb-5"
            >
                Hébergement
            </h2>

            <!-- Camping -->
            <div class="mb-5">
                <p
                    class="font-black text-sm text-[#3d1080] mb-2 uppercase tracking-wide"
                >
                    Camping sur place
                </p>
                <ul class="text-sm text-[#444] space-y-1 leading-relaxed">
                    <li>Emplacement tente : 15€ / nuit</li>
                    <li>Accès aux sanitaires et douches</li>
                    <li>Animations et food trucks à proximité</li>
                    <li>Ambiance conviviale garantie</li>
                </ul>
            </div>

            <!-- Hôtels -->
            <div class="mb-5">
                <p
                    class="font-black text-sm text-[#3d1080] mb-2 uppercase tracking-wide"
                >
                    Hôtels partenaires à Belfort
                </p>
                <ul class="text-sm text-[#444] space-y-2 leading-relaxed">
                    <li>
                        <span class="font-semibold text-[#1a1a2e]"
                            >Ibis Belfort Centre</span
                        >
                        – À partir de 75€ / nuit<br />
                        <span class="text-xs text-[#888]"
                            >Distance : 12 km du festival</span
                        >
                    </li>
                    <li>
                        <span class="font-semibold text-[#1a1a2e]"
                            >Campanile Belfort Montbéliard</span
                        >
                        – À partir de 65€ / nuit<br />
                        <span class="text-xs text-[#888]"
                            >Distance : 10 km du festival</span
                        >
                    </li>
                    <li>
                        <span class="font-semibold text-[#1a1a2e]"
                            >Best Western Belfort</span
                        >
                        – À partir de 90€ / nuit<br />
                        <span class="text-xs text-[#888]"
                            >Distance : 11 km du festival</span
                        >
                    </li>
                </ul>
                <p class="text-xs text-[#e8705a] font-semibold mt-2">
                    Tarifs préférentiels avec le code <strong
                        >LUMIMIX2026</strong
                    >
                </p>
            </div>

            <!-- Autres options -->
            <div>
                <p
                    class="font-black text-sm text-[#3d1080] mb-1 uppercase tracking-wide"
                >
                    Autres options
                </p>
                <ul class="text-sm text-[#444] space-y-1">
                    <li>Campings municipaux dans un rayon de 15 km</li>
                    <li>Auberges de jeunesse à Belfort centre</li>
                </ul>
            </div>
        </section>

        <!-- -- TRANSPORT -- -->
        <section>
            <h2
                class="text-sm font-black uppercase tracking-widest text-[#1a1a2e] mb-5"
            >
                Transport
            </h2>

            <div class="space-y-5">
                {
                    [
                        {
                            titre: "En voiture",
                            items: [
                                "Depuis Besançon : 1h via A36 (sortie Belfort-Centre). Dépuis Mulhouse : 30 min via A36 (sortie Belfort-Sud).",
                                "Depuis Strasbourg : 1h30 via A35 puis A36. Parkings gratuits à proximité du festival.",
                                "Covoiturage prioritaire avec places réservées.",
                            ],
                        },
                        {
                            titre: "En train",
                            items: [
                                "Gare de Belfort-Montbéliard TGV : 15 km du festival. Navettes gratuites depuis la gare toutes les 30 minutes. Horaires : 19h00 – 04h00.",
                                "Depuis Paris : 2h30 en TGV. Depuis Lyon : 2h15 en TGV. Depuis Strasbourg : direct, 45 min.",
                            ],
                        },
                        {
                            titre: "Covoiturage",
                            items: [
                                "Espace dédié sur notre site pour organiser vos trajets.",
                                "Parking prioritaire pour les covoitureurs.",
                                "Réduction de 5€ sur votre billet avec la preuve de covoiturage.",
                            ],
                        },
                        {
                            titre: "Transports en commun locaux",
                            items: [
                                "Bus spéciaux depuis Belfort centre-ville.",
                                "Ligne directe toutes les 20 minutes de 19h à 04h.",
                                "Tarif : 2€ l'aller simple.",
                            ],
                        },
                    ].map(({ titre, items }) => (
                        <div>
                            <p class="font-black text-sm text-[#3d1080] mb-2 uppercase tracking-wide">
                                {titre}
                            </p>
                            <ul class="text-sm text-[#444] space-y-1 leading-relaxed list-none">
                                {items.map((it) => (
                                    <li>{it}</li>
                                ))}
                            </ul>
                        </div>
                    ))
                }
            </div>
        </section>

        <!-- -- FAQ -- -->
        <section id="faq">
            <h2
                class="text-sm font-black uppercase tracking-widest text-[#1a1a2e] mb-5"
            >
                FAQ
            </h2>

            <div class="space-y-3" id="faq-list">
                {
                    faqItems.map((item, i) => (
                        <div
                            class="faq-item rounded-2xl overflow-hidden"
                            data-index={i}
                        >
                            <button
                                class="faq-btn w-full flex items-center justify-between gap-3 px-5 py-3
                                   text-white font-black uppercase tracking-wide text-xs text-left
                                   active:scale-[0.98] transition-transform"
                                style="background:linear-gradient(135deg,#e8705a,#c0407e)"
                                aria-expanded="false"
                                aria-controls={`faq-panel-${i}`}
                            >
                                <span>{item.question}</span>
                                <span
                                    class="faq-icon shrink-0 text-xl font-thin leading-none select-none"
                                    aria-hidden="true"
                                >
                                    ×
                                </span>
                            </button>
                            <div
                                id={`faq-panel-${i}`}
                                class="faq-panel max-h-0 overflow-hidden transition-[max-height] duration-300 ease-in-out"
                                role="region"
                            >
                                <div class="bg-white/60 px-5 py-4 text-sm text-[#333] leading-relaxed">
                                    {item.reponse}
                                </div>
                            </div>
                        </div>
                    ))
                }
            </div>
        </section>
    </div>

    <!-- Bande décorative avant footer -->
    <div
        class="relative h-32 overflow-hidden"
        style="background:linear-gradient(to bottom,#ede8d5,#3d1080)"
    >
        <img
            src="/cloud.svg"
            alt=""
            aria-hidden="true"
            class="absolute bottom-0 left-0 w-full h-auto pointer-events-none opacity-40"
        />
    </div>

    <Footer />
</Layout>

<script>
    /* FAQ Accordion */
    document.addEventListener("DOMContentLoaded", () => {
        // Open first item by default
        const firstBtn = document.querySelector<HTMLButtonElement>(".faq-btn");
        const firstPanel = firstBtn?.nextElementSibling as HTMLElement | null;
        if (firstBtn && firstPanel) {
            firstBtn.setAttribute("aria-expanded", "true");
            firstPanel.style.maxHeight = `${firstPanel.scrollHeight}px`;
        }

        document
            .querySelectorAll<HTMLButtonElement>(".faq-btn")
            .forEach((btn) => {
                btn.addEventListener("click", () => {
                    const panel = btn.nextElementSibling as HTMLElement | null;
                    if (!panel) return;
                    const isOpen = btn.getAttribute("aria-expanded") === "true";

                    // Close all
                    document
                        .querySelectorAll<HTMLButtonElement>(".faq-btn")
                        .forEach((b) => {
                            const p =
                                b.nextElementSibling as HTMLElement | null;
                            b.setAttribute("aria-expanded", "false");
                            if (p) p.style.maxHeight = "0";
                        });

                    // Re-open if it was closed
                    if (!isOpen) {
                        btn.setAttribute("aria-expanded", "true");
                        panel.style.maxHeight = `${panel.scrollHeight}px`;
                    }
                });
            });
    });
</script>
