---
/**
 * InfoCTA.astro — Bloc date + lieu + CTA réservation
 * "7, 8 ET 9 AOÛT 2026 · Presqu'île de Malsaucy, Belfort · 3 nuits inoubliables"
 */
---

<section class="bg-[#ede8d5] px-6 py-8 border-t border-[#d6d0bc]">
    <div class="max-w-2xl mx-auto space-y-3">
        <!-- Date -->
        <h2 class="text-3xl sm:text-4xl font-black text-[#1a1a2e] leading-tight uppercase tracking-tight">
            7, 8 ET 9<br class="sm:hidden"/> AOÛT 2026
        </h2>

        <!-- Lieu -->
        <p class="text-base sm:text-lg font-medium text-[#333]">
            Presqu'île de Malsaucy, Belfort
        </p>

        <!-- Accroche -->
        <p class="text-base text-[#555]">
            3 nuits inoubliables
        </p>

        <!-- CTA -->
        <a
            href="/billetterie"
            class="inline-block mt-4 px-6 py-3 rounded-full border-2 border-[#1a1a2e]
                   text-sm font-black uppercase tracking-widest text-[#1a1a2e]
                   hover:bg-[#1a1a2e] hover:text-white
                   active:scale-95 transition-all duration-150 focus:outline-none
                   focus-visible:ring-2 focus-visible:ring-[#1a1a2e]"
        >
            Réserve ta place
        </a>
    </div>
</section>
