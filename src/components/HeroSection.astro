---
/**
 * HeroSection.astro — Hero pleine page de la page d'accueil Lumimix Festival
 */
---

<section
    class="relative w-full min-h-screen overflow-hidden
           bg-linear-to-b from-[#e8705a] via-[#c0407e] to-[#3d1080]"
    aria-label="Bienvenue au Lumimix Festival"
>
    <!-- ── Calque nuages ── -->
    <!-- Nuages haut gauche -->
    <img src="/cloud.png" alt="" aria-hidden="true"
        class="absolute -top-4 -left-8 w-3/4 pointer-events-none select-none z-10 opacity-90" />
    <!-- Nuages haut droite (retournés) -->
    <img src="/cloud.png" alt="" aria-hidden="true"
        class="absolute -top-4 -right-8 w-2/3 pointer-events-none select-none z-10 opacity-80 scale-x-[-1]" />
    <!-- Nuage milieu gauche -->
    <img src="/cloud.png" alt="" aria-hidden="true"
        class="absolute top-[38%] -left-12 w-1/2 pointer-events-none select-none z-10 opacity-50" />
    <!-- Nuages bas gauche -->
    <img src="/cloud.png" alt="" aria-hidden="true"
        class="absolute -bottom-4 -left-8 w-3/4 pointer-events-none select-none z-10 opacity-95" />
    <!-- Nuages bas droite (retournés) -->
    <img src="/cloud.png" alt="" aria-hidden="true"
        class="absolute -bottom-4 -right-8 w-2/3 pointer-events-none select-none z-10 opacity-90 scale-x-[-1]" />

    <!-- ── Calque drones ── -->
    <!-- Haut droite -->
    <img src="/drone.png" alt="" aria-hidden="true"
        class="absolute top-[8%] right-[18%] w-14 pointer-events-none select-none z-20" />
    <img src="/drone.png" alt="" aria-hidden="true"
        class="absolute top-[16%] right-[5%] w-11 pointer-events-none select-none z-20" />
    <!-- Haut gauche -->
    <img src="/drone.png" alt="" aria-hidden="true"
        class="absolute top-[13%] left-[8%] w-13 pointer-events-none select-none z-20" />
    <img src="/drone.png" alt="" aria-hidden="true"
        class="absolute top-[28%] left-[3%] w-10 pointer-events-none select-none z-20" />
    <!-- Milieu droite -->
    <img src="/drone.png" alt="" aria-hidden="true"
        class="absolute top-[47%] right-[4%] w-12 pointer-events-none select-none z-20" />
    <!-- Milieu gauche -->
    <img src="/drone.png" alt="" aria-hidden="true"
        class="absolute top-[57%] left-[5%] w-13 pointer-events-none select-none z-20" />
    <!-- Bas droite -->
    <img src="/drone.png" alt="" aria-hidden="true"
        class="absolute top-[71%] right-[18%] w-11 pointer-events-none select-none z-20" />
    <img src="/drone.png" alt="" aria-hidden="true"
        class="absolute top-[82%] right-[6%] w-12 pointer-events-none select-none z-20" />
    <!-- Bas gauche -->
    <img src="/drone.png" alt="" aria-hidden="true"
        class="absolute top-[76%] left-[18%] w-12 pointer-events-none select-none z-20" />

    <!-- ── Contenu principal ── -->
    <div
        class="relative z-30 flex flex-col items-center
               min-h-screen pt-24 pb-16 px-6"
    >
        <!-- Personnage DJ centré dans un cercle lumineux — occupe la moitié haute -->
        <div class="flex-1 flex items-center justify-center w-full">
            <div
                class="relative flex items-center justify-center
                       w-52 h-52 sm:w-60 sm:h-60 md:w-72 md:h-72
                       rounded-full
                       bg-[#8055c8]/55
                       shadow-[0_0_90px_45px_rgba(111,66,193,0.45)]"
            >
                <img
                    src="/character.png"
                    alt="Personnage DJ du Lumimix Festival avec écouteurs sur des platines"
                    class="w-[90%] h-[90%] object-contain drop-shadow-[0_4px_16px_rgba(0,0,0,0.4)]"
                />
            </div>
        </div>

        <!-- Tagline -->
        <p
            class="text-center text-white font-black uppercase
                   leading-tight tracking-wider
                   text-2xl sm:text-3xl
                   drop-shadow-[0_2px_10px_rgba(0,0,0,0.55)]"
        >
            OSE LA LUMIÈRE,<br />
            OSE LE SONVIENS<br />
            VIVRE LA NUIT À LUMIMIX
        </p>
    </div>
</section>
