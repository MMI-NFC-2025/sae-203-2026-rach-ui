---
/**
 * Footer.astro — Pied de page Lumimix Festival
 * Sections : logo · navigation · contact · réseaux sociaux · légal · sponsors
 */
---

<footer class="bg-[#1a1a2e] text-white px-6 pt-10 pb-6 mt-0">
    <!-- Logo + identité festival -->
    <div class="flex items-center gap-3 mb-6">
        <img
            src="/logo.png"
            alt="Lumimix Festival"
            class="w-16 h-16 object-contain rounded-full"
        />
        <div>
            <p
                class="font-black uppercase tracking-wider text-sm leading-tight"
            >
                Lumimix Festival<br />7-8-9 Août 2026
            </p>
            <p class="text-white/60 text-xs mt-0.5">Malsaucy, Belfort</p>
        </div>
    </div>

    <!-- Navigation en 2 colonnes -->
    <div class="mb-6">
        <p
            class="text-xs font-black uppercase tracking-widest text-white/50 mb-3"
        >
            Navigation
        </p>
        <div class="grid grid-cols-2 gap-x-8 gap-y-2">
            {
                [
                    { label: "Le Festival", href: "/" },
                    { label: "Scènes", href: "/scenes" },
                    { label: "Programme", href: "/programme" },
                    { label: "Infos pratiques", href: "/infos" },
                    { label: "Artistes", href: "/artistes" },
                    { label: "Contact", href: "/contact" },
                ].map(({ label, href }) => (
                    <a
                        href={href}
                        class="text-sm text-white/80 hover:text-white
                           transition-colors duration-150 focus:outline-none focus-visible:underline"
                    >
                        {label}
                    </a>
                ))
            }
        </div>
    </div>

    <!-- Contact -->
    <div class="mb-6">
        <p
            class="text-xs font-black uppercase tracking-widest text-white/50 mb-2"
        >
            Contact
        </p>
        <a
            href="mailto:contact@lumimix-festival.fr"
            class="text-sm text-white/80 hover:text-white transition-colors duration-150"
        >
            contact@lumimix-festival.fr
        </a>
        <p class="text-sm text-white/60 mt-1">XX.XX.XX.XX.XX</p>
    </div>

    <!-- Réseaux sociaux + Légal en 2 colonnes -->
    <div class="grid grid-cols-2 gap-x-8 mb-8">
        <!-- Réseaux -->
        <div>
            <p
                class="text-xs font-black uppercase tracking-widest text-white/50 mb-3"
            >
                Réseaux sociaux
            </p>
            <div class="flex gap-4">
                <!-- Instagram -->
                <a
                    href="#"
                    aria-label="Instagram"
                    class="text-white/70 hover:text-white transition-colors"
                >
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        class="w-6 h-6"
                        fill="currentColor"
                        viewBox="0 0 24 24"
                    >
                        <path
                            d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"
                        ></path>
                    </svg>
                </a>
                <!-- Facebook -->
                <a
                    href="#"
                    aria-label="Facebook"
                    class="text-white/70 hover:text-white transition-colors"
                >
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        class="w-6 h-6"
                        fill="currentColor"
                        viewBox="0 0 24 24"
                    >
                        <path
                            d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"
                        ></path>
                    </svg>
                </a>
                <!-- YouTube -->
                <a
                    href="#"
                    aria-label="YouTube"
                    class="text-white/70 hover:text-white transition-colors"
                >
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        class="w-6 h-6"
                        fill="currentColor"
                        viewBox="0 0 24 24"
                    >
                        <path
                            d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"
                        ></path>
                    </svg>
                </a>
            </div>
        </div>

        <!-- Légal -->
        <div>
            <p
                class="text-xs font-black uppercase tracking-widest text-white/50 mb-3"
            >
                Légal
            </p>
            <div class="space-y-2">
                <a
                    href="/mentions-legales"
                    class="block text-sm text-white/70 hover:text-white transition-colors"
                >
                    Mentions légales
                </a>
                <a
                    href="/cgv"
                    class="block text-sm text-white/70 hover:text-white transition-colors"
                >
                    CGV
                </a>
                <a
                    href="/confidentialite"
                    class="block text-sm text-white/70 hover:text-white transition-colors"
                >
                    Politique de confidentialité
                </a>
            </div>
        </div>
    </div>

    <!-- Séparateur -->
    <div class="border-t border-white/10 pt-6">
        <!-- Logos sponsors -->
        <p
            class="text-xs font-black uppercase tracking-widest text-white/40 mb-4 text-center"
        >
            Partenaires
        </p>
        <div
            class="flex flex-wrap items-center justify-center gap-6 grayscale opacity-60"
        >
            <span class="text-white font-bold text-sm tracking-widest"
                >Thomann</span
            >
            <span class="text-white font-bold text-sm tracking-widest"
                >Red Bull</span
            >
            <span class="text-white font-bold text-sm tracking-widest"
                >L'Est Républicain</span
            >
            <span class="text-white font-bold text-sm tracking-widest"
                >Pioneer DJ</span
            >
        </div>

        <!-- Copyright -->
        <p class="text-center text-xs text-white/30 mt-6">
            © 2026 Lumimix Festival. Tous droits réservés.
        </p>
    </div>
</footer>
