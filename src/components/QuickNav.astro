---
/**
 * QuickNav.astro — 3 icônes de navigation rapide sous le hero
 * (Programme · Artistes · Infos pratiques)
 */
---

<section class="bg-[#ede8d5] py-8 px-6">
    <div class="max-w-xs mx-auto grid grid-cols-3 gap-4 text-center">
        <!-- Programme -->
        <a
            href="/programme"
            class="flex flex-col items-center gap-2 group focus:outline-none"
        >
            <div
                class="w-16 h-16 rounded-full bg-[#e87b5a] flex items-center justify-center
                        shadow-md group-hover:scale-105 group-active:scale-95 transition-transform duration-150"
            >
                <img
                    src="/icon programme.png"
                    alt=""
                    aria-hidden="true"
                    class="w-10 h-10 object-contain"
                />
            </div>
            <span
                class="text-xs font-semibold text-[#333] tracking-wide uppercase"
                >Programme</span
            >
        </a>

        <!-- Artistes -->
        <a
            href="/artistes"
            class="flex flex-col items-center gap-2 group focus:outline-none"
        >
            <div
                class="w-16 h-16 rounded-full bg-[#c0407e] flex items-center justify-center
                        shadow-md group-hover:scale-105 group-active:scale-95 transition-transform duration-150"
            >
                <img
                    src="/icon artistes.png"
                    alt=""
                    aria-hidden="true"
                    class="w-10 h-10 object-contain"
                />
            </div>
            <span
                class="text-xs font-semibold text-[#333] tracking-wide uppercase"
                >Artistes</span
            >
        </a>

        <!-- Infos pratiques -->
        <a
            href="/infos"
            class="flex flex-col items-center gap-2 group focus:outline-none"
        >
            <div
                class="w-16 h-16 rounded-full bg-[#3d1080] flex items-center justify-center
                        shadow-md group-hover:scale-105 group-active:scale-95 transition-transform duration-150"
            >
                <img
                    src="/icon infos pratiques.png"
                    alt=""
                    aria-hidden="true"
                    class="w-10 h-10 object-contain"
                />
            </div>
            <span
                class="text-xs font-semibold text-[#333] tracking-wide uppercase leading-tight"
            >
                Infos<br />pratiques
            </span>
        </a>
    </div>
</section>
