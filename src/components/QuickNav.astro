---
/**
 * QuickNav.astro — 3 icônes de navigation rapide sous le hero
 * (Programme · Artistes · Infos pratiques)
 */
---

<section class="bg-[#ede8d5] py-8 px-6">
    <div class="max-w-xs mx-auto grid grid-cols-3 gap-4 text-center">
        <!-- Programme -->
        <a
            href="/programme"
            class="flex flex-col items-center gap-2 group focus:outline-none"
        >
            <div class="w-16 h-16 rounded-full bg-[#e87b5a] flex items-center justify-center
                        shadow-md group-hover:scale-105 group-active:scale-95 transition-transform duration-150">
                <!-- Icône programme (calendrier/liste) -->
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 40 40" class="w-8 h-8" fill="none">
                    <rect x="6" y="10" width="28" height="24" rx="4" stroke="white" stroke-width="2.5"/>
                    <line x1="13" y1="7" x2="13" y2="14" stroke="white" stroke-width="2.5" stroke-linecap="round"/>
                    <line x1="27" y1="7" x2="27" y2="14" stroke="white" stroke-width="2.5" stroke-linecap="round"/>
                    <line x1="6" y1="18" x2="34" y2="18" stroke="white" stroke-width="2"/>
                    <line x1="12" y1="24" x2="20" y2="24" stroke="white" stroke-width="2" stroke-linecap="round"/>
                    <line x1="12" y1="29" x2="24" y2="29" stroke="white" stroke-width="2" stroke-linecap="round"/>
                </svg>
            </div>
            <span class="text-xs font-semibold text-[#333] tracking-wide uppercase">Programme</span>
        </a>

        <!-- Artistes -->
        <a
            href="/artistes"
            class="flex flex-col items-center gap-2 group focus:outline-none"
        >
            <div class="w-16 h-16 rounded-full bg-[#c0407e] flex items-center justify-center
                        shadow-md group-hover:scale-105 group-active:scale-95 transition-transform duration-150">
                <!-- Icône artiste (personne + note) -->
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 40 40" class="w-8 h-8" fill="none">
                    <circle cx="20" cy="13" r="6" stroke="white" stroke-width="2.5"/>
                    <path d="M8 34c0-6.627 5.373-12 12-12s12 5.373 12 12" stroke="white" stroke-width="2.5" stroke-linecap="round"/>
                    <circle cx="30" cy="12" r="3" fill="white"/>
                    <line x1="30" y1="12" x2="35" y2="9" stroke="white" stroke-width="2" stroke-linecap="round"/>
                    <line x1="35" y1="9" x2="35" y2="5" stroke="white" stroke-width="2" stroke-linecap="round"/>
                </svg>
            </div>
            <span class="text-xs font-semibold text-[#333] tracking-wide uppercase">Artistes</span>
        </a>

        <!-- Infos pratiques -->
        <a
            href="/infos"
            class="flex flex-col items-center gap-2 group focus:outline-none"
        >
            <div class="w-16 h-16 rounded-full bg-[#3d1080] flex items-center justify-center
                        shadow-md group-hover:scale-105 group-active:scale-95 transition-transform duration-150">
                <!-- Icône infos (i dans cercle) -->
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 40 40" class="w-8 h-8" fill="none">
                    <circle cx="20" cy="20" r="14" stroke="white" stroke-width="2.5"/>
                    <line x1="20" y1="18" x2="20" y2="29" stroke="white" stroke-width="3" stroke-linecap="round"/>
                    <circle cx="20" cy="13" r="1.8" fill="white"/>
                </svg>
            </div>
            <span class="text-xs font-semibold text-[#333] tracking-wide uppercase leading-tight">
                Infos<br/>pratiques
            </span>
        </a>
    </div>
</section>
